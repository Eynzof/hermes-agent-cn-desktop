{
  "name": "hermes-agent-cn-desktop",
  "version": "0.2.0",
  "private": true,
  "author": "Hermes Agent CN Contributors",
  "homepage": "https://hermesagent.org.cn",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm web:dev",
    "web:dev": "pnpm --filter @hermes/web dev",
    "web:build": "pnpm --filter @hermes/web build",
    "web:build:desktop": "pnpm --filter @hermes/web build:desktop",
    "runtime:install-local": "node scripts/install-local-runtime.mjs",
    "tauri:dev": "node scripts/tauri-dev-managed.mjs",
    "tauri:dev:managed": "node scripts/tauri-dev-managed.mjs",
    "tauri:dev:external": "node scripts/tauri-dev-external.mjs",
    "tauri:build": "pnpm exec tauri build",
    "tauri:build:debug": "pnpm exec tauri build --debug",
    "tauri:run": "cargo run",
    "typecheck": "pnpm -r run typecheck",
    "test:unit": "pnpm -r --workspace-concurrency=1 test:unit",
    "runtime:stage-bundled-windows": "node scripts/stage-bundled-runtime.mjs --platform win32 --arch x64",
    "runtime:stage-bundled-macos": "node scripts/stage-bundled-runtime.mjs --platform darwin --arch arm64",
    "dashboard:stage-web-dist": "node scripts/stage-dashboard-web-dist.mjs",
    "skills:stage-bundled": "node scripts/stage-bundled-skills.mjs",
    "bundle:stage-windows": "pnpm run runtime:stage-bundled-windows && pnpm run dashboard:stage-web-dist && pnpm run skills:stage-bundled",
    "bundle:stage-macos": "pnpm run runtime:stage-bundled-macos && pnpm run dashboard:stage-web-dist && pnpm run skills:stage-bundled",
    "tauri:build:bundled-windows": "pnpm run bundle:stage-windows && pnpm exec tauri build --bundles nsis",
    "tauri:build:bundled-macos": "pnpm run bundle:stage-macos && pnpm exec tauri build --bundles dmg"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0"
  }
}
